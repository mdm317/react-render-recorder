{
  "name": "react-record",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/react-record.js",
  "module": "./dist/react-record.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-record.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:lib": "vite build --watch",
    "build": "rm -rf dist && vite build && tsc -p tsconfig.build.json",
    "build:dev-web": "vite build --mode dev-web",
    "preview:dev-web": "vite preview --outDir dist-dev-web",
    "verify:regression": "node scripts/verify-regression.mjs",
    "test:e2e": "playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "devtools-api": "workspace:*",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "@playwright/test": "^1.51.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
