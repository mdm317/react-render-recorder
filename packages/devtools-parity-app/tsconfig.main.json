{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": [
    "src/ipc-channels.ts",
    "src/main.ts",
    "src/preload.ts",
    "src/windows/compare/index.ts",
    "src/windows/home/index.ts",
    "src/windows/target/index.ts",
    "src/windows/target/target-window.ts",
    "src/windows/target/eval-on-target.ts",
    "src/recorder/server.ts",
    "src/recorder/inject-script.ts",
    "src/recorder/controls.ts",
    "src/devtools-standalone/inject-backend.ts",
    "src/devtools-standalone/inject-profiler-tap.ts",
    "src/devtools-standalone/controls.ts"
  ]
}
