{
  "name": "react-record-workspace",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter react-record dev",
    "build": "pnpm --filter devtools-api build && pnpm --filter react-record build && pnpm --filter react-record build:demo",
    "build:devtools-api": "pnpm --filter devtools-api build",
    "build:demo": "pnpm --filter react-record build:demo",
    "build:react-record": "pnpm --filter react-record build"
  },
  "workspaces": [
    "packages/*"
  ]
}
